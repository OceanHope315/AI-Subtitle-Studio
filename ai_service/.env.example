DATA_DIR=../data
SAMPLE_FPS=2.0
OCR_ROI_TOP=0.45
OCR_ROI_BOTTOM=0.84
OCR_LANGUAGE=en
MIN_OCR_CONFIDENCE=0.55
MIN_EVENT_DURATION=0.10
REFINE_OCR_BOUNDARIES=true
BOUNDARY_OCR_BUDGET=2
DISCOVER_SHORT_EVENTS=true
DISCOVERY_OCR_BUDGET=24
DISCOVERY_CHANGE_THRESHOLD=2.0
ENABLE_WHISPER=true
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
MAX_UPLOAD_MB=2048
PREVIEW_INTERVAL_SECONDS=1.0
PREVIEW_RING_SIZE=8
PREVIEW_MAX_LONG_EDGE=800
PREVIEW_JPEG_QUALITY=80
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
