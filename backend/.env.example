# HTTP
HOST=0.0.0.0
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
JSON_LIMIT=10mb
MAX_UPLOAD_MB=1024

# Runtime data (relative paths are resolved from the process working directory)
DATA_DIR=../data
# UPLOAD_DIR=../data/videos
# SUBTITLE_DIR=../data/subtitles
# FILE_DB_PATH=../data/tasks.json

# MongoDB is optional. Without this value, JSON file persistence is used.
# MONGODB_URI=mongodb://127.0.0.1:27017/ai_subtitle_studio
# MONGODB_DB_NAME=ai_subtitle_studio
MONGODB_CONNECT_TIMEOUT_MS=3000
MONGODB_FALLBACK_TO_FILE=true

# Python FastAPI service
AI_SERVICE_URL=http://127.0.0.1:8000
AI_REQUEST_TIMEOUT_MS=120000
AI_POLL_INTERVAL_MS=2000
AI_POLL_MAX_ATTEMPTS=900
AI_POLL_MAX_ERRORS=5
